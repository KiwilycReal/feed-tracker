require "base64"
require "json"
require "shellwords"

default_platform(:ios)

def repo_root
  workspace = ENV.fetch("GITHUB_WORKSPACE", "").to_s.strip
  return workspace unless workspace.empty? || !Dir.exist?(workspace)

  File.expand_path("..", __dir__)
end

def resolve_repo_path(path)
  raw = path.to_s.strip
  return raw if raw.empty?
  return raw if File.exist?(raw)

  expanded = File.expand_path(raw, repo_root)
  return expanded if File.exist?(expanded)

  raw
end

def load_signing_config!
  path = ENV.fetch("CI_SIGNING_CONFIG_PATH", "").to_s.strip
  path = "ci/signing-targets.json" if path.empty?
  path = resolve_repo_path(path)
  UI.user_error!("Signing config not found: #{path}") unless File.exist?(path)

  config = JSON.parse(File.read(path))
  targets = config.fetch("targets", [])
  UI.user_error!("Signing config targets is empty: #{path}") if targets.empty?

  [path, config]
end

def configured_bundle_ids(config)
  config.fetch("targets", []).map { |item| item.fetch("bundle_id") }
end

def configured_profile_mapping(config)
  config.fetch("targets", []).to_h do |item|
    [item.fetch("bundle_id"), item.fetch("profile_name")]
  end
end

def release_project_path(config)
  ENV.fetch("CI_XCODE_PROJECT", "").strip.tap do |value|
    return resolve_repo_path(value) unless value.empty?
  end

  resolve_repo_path(config.fetch("project_path", "").to_s)
end

def release_workspace_path
  resolve_repo_path(ENV.fetch("CI_XCODE_WORKSPACE", "").strip)
end

def release_scheme(config)
  ENV.fetch("CI_XCODE_SCHEME", "").strip.tap do |value|
    return value unless value.empty?
  end

  config.fetch("scheme", "").to_s
end

def release_primary_bundle_id(config, bundle_ids)
  from_env = ENV.fetch("CI_APP_IDENTIFIER", "").strip
  return from_env unless from_env.empty?

  from_config = config.fetch("primary_bundle_id", "").to_s
  return from_config unless from_config.empty?

  bundle_ids.first
end

def assert_required_env!(keys, lane_name)
  missing = keys.select { |key| ENV.fetch(key, "").strip.empty? }
  return if missing.empty?

  UI.user_error!("Missing required #{lane_name} keys: #{missing.join(', ')}")
end

def run_signing_readiness_check!(config_path:, mode:)
  script = File.expand_path("scripts/ci/check_signing_readiness.py", repo_root)
  quoted_script = Shellwords.escape(script)
  quoted_path = Shellwords.escape(config_path)
  quoted_mode = Shellwords.escape(mode)
  sh("python3 #{quoted_script} --config #{quoted_path} --mode #{quoted_mode} --repo-root #{Shellwords.escape(repo_root)}")
end

def match_readonly_mode
  ENV.fetch("MATCH_READONLY", "true").to_s.strip.downcase != "false"
end

def current_project_build_number(project_path)
  pbxproj_path = File.join(project_path, "project.pbxproj")
  return 0 unless File.exist?(pbxproj_path)

  File.read(pbxproj_path).scan(/CURRENT_PROJECT_VERSION = (\d+);/).flatten.map(&:to_i).max || 0
end

def release_build_number_timestamp
  timezone = ENV.fetch("CI_BUILD_NUMBER_TIMEZONE", "Australia/Melbourne")
  original_timezone = ENV["TZ"]
  ENV["TZ"] = timezone

  Time.now.strftime("%Y%m%d%H%M%S").to_i
ensure
  if original_timezone.nil?
    ENV.delete("TZ")
  else
    ENV["TZ"] = original_timezone
  end
end

def next_release_build_number(project_path)
  manual_override = ENV.fetch("CI_BUILD_NUMBER", "").to_s.strip
  return manual_override unless manual_override.empty?

  timestamp_candidate = release_build_number_timestamp
  project_candidate = current_project_build_number(project_path) + 1

  [timestamp_candidate, project_candidate].max.to_s
end

platform :ios do
  desc "Readonly TestFlight release lane (single CI path)."
  lane :testflight_release do
    assert_required_env!(
      %w[
        APP_STORE_CONNECT_API_KEY_ID
        APP_STORE_CONNECT_API_ISSUER_ID
        APP_STORE_CONNECT_API_KEY_BASE64
        APPLE_TEAM_ID
        MATCH_PASSWORD
        MATCH_GIT_BASIC_AUTHORIZATION
        KEYCHAIN_PASSWORD
        MATCH_GIT_URL
      ],
      "testflight_release"
    )

    config_path, config = load_signing_config!
    bundle_ids = configured_bundle_ids(config)
    profile_mapping = configured_profile_mapping(config)

    run_signing_readiness_check!(config_path: config_path, mode: "config")

    workspace = release_workspace_path
    project = release_project_path(config)
    scheme = release_scheme(config)
    bundle_id = release_primary_bundle_id(config, bundle_ids)

    if workspace.empty? && project.empty?
      UI.user_error!("Set CI_XCODE_WORKSPACE or CI_XCODE_PROJECT (or project_path in signing config)")
    end

    UI.user_error!("Set CI_XCODE_SCHEME (or scheme in signing config)") if scheme.to_s.strip.empty?
    UI.user_error!("Unable to determine primary bundle identifier") if bundle_id.to_s.strip.empty?

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_BASE64"]),
      is_key_content_base64: false,
      in_house: false
    )

    create_keychain(
      name: "fastlane_tmp.keychain",
      password: ENV["KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: true
    )

    begin
      match(
        type: "appstore",
        app_identifier: bundle_ids,
        readonly: match_readonly_mode,
        git_url: ENV["MATCH_GIT_URL"],
        api_key: api_key,
        git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"],
        keychain_name: "fastlane_tmp.keychain",
        keychain_password: ENV["KEYCHAIN_PASSWORD"],
        team_id: ENV["APPLE_TEAM_ID"]
      )
    rescue => _error
      UI.user_error!(
        "ERROR_ONE_LINE: signing profiles are not ready for current bundle IDs | ACTION: provision/update profiles out-of-band, then re-run release workflow."
      )
    end

    run_signing_readiness_check!(config_path: config_path, mode: "profiles")

    target_configs = config.fetch("targets", [])
    target_configs.each do |target_cfg|
      target_name = target_cfg.fetch("target")
      profile_name = target_cfg.fetch("profile_name")
      bundle_identifier = target_cfg.fetch("bundle_id")

      update_code_signing_settings(
        use_automatic_signing: false,
        path: project,
        targets: [target_name],
        build_configurations: ["Release"],
        team_id: ENV["APPLE_TEAM_ID"],
        code_sign_identity: "Apple Distribution",
        profile_name: profile_name,
        bundle_identifier: bundle_identifier
      )
    end

    build_options = {
      clean: true,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "feed-tracker.ipa",
      include_symbols: true,
      include_bitcode: false,
      export_options: {
        provisioningProfiles: profile_mapping
      },
      xcargs: "DEVELOPMENT_TEAM=#{ENV["APPLE_TEAM_ID"]}"
    }

    if workspace.empty?
      build_options[:project] = project
    else
      build_options[:workspace] = workspace
    end
    build_options[:scheme] = scheme

    build_number = next_release_build_number(project)
    increment_build_number(
      build_number: build_number,
      xcodeproj: project
    )
    UI.message("Using CI release build number #{build_number}")

    build_app(build_options)

    upload_to_testflight(
      api_key: api_key,
      app_identifier: bundle_id,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )

    UI.success("Readonly TestFlight release completed for #{bundle_id} (scheme: #{scheme})")
  end
end
