default_platform(:ios)

platform :ios do
  desc "Build and upload iOS app to TestFlight"
  lane :testflight do
    required_env_keys = %w[
      APP_STORE_CONNECT_API_KEY_ID
      APP_STORE_CONNECT_API_ISSUER_ID
      APP_STORE_CONNECT_API_KEY_BASE64
      APPLE_TEAM_ID
      MATCH_PASSWORD
      MATCH_GIT_BASIC_AUTHORIZATION
      KEYCHAIN_PASSWORD
    ]

    missing = required_env_keys.select { |key| ENV.fetch(key, "").strip.empty? }
    unless missing.empty?
      UI.user_error!("Missing required release secrets: #{missing.join(', ')}")
    end

    workspace = ENV["CI_XCODE_WORKSPACE"].to_s.strip
    project = ENV["CI_XCODE_PROJECT"].to_s.strip
    scheme = ENV["CI_XCODE_SCHEME"].to_s.strip
    bundle_id = ENV["CI_APP_IDENTIFIER"].to_s.strip
    match_git_url = ENV["MATCH_GIT_URL"].to_s.strip

    if workspace.empty? && project.empty?
      UI.user_error!("Set CI_XCODE_WORKSPACE or CI_XCODE_PROJECT before release deploy")
    end

    if scheme.empty?
      UI.user_error!("Set CI_XCODE_SCHEME before release deploy")
    end

    if bundle_id.empty?
      UI.user_error!("Set CI_APP_IDENTIFIER (bundle id) before release deploy")
    end

    if match_git_url.empty?
      UI.user_error!("Set MATCH_GIT_URL (certificates repo HTTPS URL) before release deploy")
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_BASE64"]),
      is_key_content_base64: false,
      in_house: false
    )

    create_keychain(
      name: "fastlane_tmp.keychain",
      password: ENV["KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: true
    )

    match(
      type: "appstore",
      app_identifier: [bundle_id],
      readonly: true,
      git_url: match_git_url,
      api_key: api_key,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"],
      keychain_name: "fastlane_tmp.keychain",
      keychain_password: ENV["KEYCHAIN_PASSWORD"],
      team_id: ENV["APPLE_TEAM_ID"]
    )

    build_options = {
      clean: true,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "feed-tracker.ipa",
      include_symbols: true,
      include_bitcode: false,
      xcargs: "-allowProvisioningUpdates"
    }

    if workspace.empty?
      build_options[:project] = project
    else
      build_options[:workspace] = workspace
    end
    build_options[:scheme] = scheme

    build_app(build_options)

    upload_to_testflight(
      api_key: api_key,
      app_identifier: bundle_id,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )

    UI.success("Uploaded build to TestFlight: #{bundle_id} (scheme: #{scheme})")
  end
end
